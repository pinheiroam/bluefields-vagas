# Supabase — obrigatórias
# Encontre essas chaves no painel do Supabase em Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role: NUNCA exponha em código que roda no browser.
# Usado somente em ambiente server (ex.: scripts administrativos / seed via supabase CLI).
# Se você não usar scripts administrativos locais, pode deixar em branco.
SUPABASE_SERVICE_ROLE_KEY=
